{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(npm run:*)",
      "Bash(grep:*)",
      "Bash(git:*)",
      "WebSearch",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:community.openai.com)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  }
}
