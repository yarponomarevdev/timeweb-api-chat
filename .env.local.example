TIMEWEB_TOKEN=your_timeweb_token_here
OPENAI_API_KEY=your_openai_api_key_here

# Модель OpenAI (по умолчанию gpt-4o)
OPENAI_MODEL=gpt-4o

# Максимальное кол-во tool-шагов за один запрос (по умолчанию 8)
CHAT_MAX_STEPS=8

# Sentry DSN для отслеживания ошибок (опционально)
# SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
